# Server Configuration
PORT=3001
NODE_ENV=development
# UPLOADS_DIR=/var/data/uploads

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/fridgemate
MONGO_URI_TEST=mongodb://localhost:27017/fridgemate_test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth Configuration (Web client and Android app)
OAUTH_CLIENT_ID=your-google-client-id
OAUTH_CLIENT_SECRET=your-google-client-secret
OAUTH_CALLBACK_URL=http://localhost:3001/auth/login/google/callback

# AI Configuration
# GEMINI_API_KEY is required - used for text generation (recipes, image search)
# GEMINI_IMAGE_API_KEY is optional - when set, enables AI image generation via Gemini image model
GEMINI_API_KEY=your-gemini-api-key
GEMINI_IMAGE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Recipe Image Search
SPOONACULAR_API_KEY=

# Email (Resend) Configuration
# Used for password reset emails. 
# Get an API key at https://resend.com -> API Keys
RESEND_API_KEY=your-resend-api-key
# Optional override. Defaults to "FridgeMate <onboarding@resend.dev>" (Resend's
# shared test sender) when unset. For production, verify your own domain in
# Resend and set this, e.g. MAIL_FROM="FridgeMate <no-reply@yourdomain.com>"
# MAIL_FROM=FridgeMate <no-reply@yourdomain.com>
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json