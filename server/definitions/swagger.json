{
  "swagger": "2.0",
  "info": {
    "title": "FridgeMate API Specification",
    "version": "1.0.0",
    "description": "Welcome to the FridgeMate API! This OpenAPI document provides a complete map of our backend services. From user management and shared fridges, to social posts, real-time chats, and AI-powered recipe generation, everything you need to interface with the app is documented below.\n\n### Authentication\nMost endpoints require a JWT access token. Include it in your requests via the `Authorization` header like so: `Bearer <your_token>`."
  },
  "host": "localhost:3001",
  "basePath": "/",
  "schemes": [
    "http",
    "https"
  ],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter your Bearer token in the format **Bearer &lt;token&gt;**"
    }
  },
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Register a new user account",
        "description": "Creates a new FridgeMate account. The display name will default to the username if not provided.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "email",
                "password"
              ],
              "properties": {
                "userName": {
                  "type": "string",
                  "example": "johndoe123"
                },
                "displayName": {
                  "type": "string",
                  "example": "John Doe"
                },
                "email": {
                  "type": "string",
                  "example": "john@example.com"
                },
                "password": {
                  "type": "string",
                  "example": "securePass123"
                },
                "profileImage": {
                  "type": "string",
                  "example": "https://example.com/avatar.jpg"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User registered successfully"
          },
          "400": {
            "description": "Validation error or user already exists"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Log in with email and password",
        "description": "Authenticates a user and returns an access token and a refresh token.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "email",
                "password"
              ],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "john@example.com"
                },
                "password": {
                  "type": "string",
                  "example": "securePass123"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful login, tokens provided"
          },
          "400": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Log out the current user",
        "description": "Invalidates the user's refresh token so it can no longer be used.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/auth/refresh-token": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Refresh access token",
        "description": "Gives you a fresh access token in exchange for a valid refresh token.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "refreshToken"
              ],
              "properties": {
                "refreshToken": {
                  "type": "string",
                  "example": "eyJhbGci..."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token refreshed successfully"
          },
          "400": {
            "description": "Invalid or expired refresh token"
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Request a password reset code",
        "description": "Sends a 6-digit reset code to the user's email address. The code expires in 15 minutes.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "email"
              ],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "john@example.com"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reset code sent to email"
          },
          "400": {
            "description": "No account found with this email"
          }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Reset password using a code",
        "description": "Verifies the 6-digit code sent via email and updates the user's password.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "email",
                "code",
                "newPassword"
              ],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "john@example.com"
                },
                "code": {
                  "type": "string",
                  "example": "847291"
                },
                "newPassword": {
                  "type": "string",
                  "example": "myNewSecurePass123"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password reset successfully"
          },
          "400": {
            "description": "Invalid or expired reset code"
          }
        }
      }
    },
    "/user": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "List all users",
        "description": "Retrieves a public list of all users in the system.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "A list of user profiles"
          }
        }
      }
    },
    "/user/{id}": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Get a specific user's profile",
        "description": "Fetches details of a user by their unique ID.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "type": "string",
            "required": true,
            "description": "Mongo Object ID of the user"
          }
        ],
        "responses": {
          "200": {
            "description": "User details returned"
          },
          "404": {
            "description": "User not found"
          }
        }
      },
      "put": {
        "tags": [
          "User"
        ],
        "summary": "Update user profile",
        "description": "Allows users to update their own profile details like display name and avatar.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "userName": {
                  "type": "string",
                  "example": "new_johndoe"
                },
                "displayName": {
                  "type": "string",
                  "example": "John D."
                },
                "profileImage": {
                  "type": "string",
                  "example": "https://example.com/new_avatar.png"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile updated successfully"
          }
        }
      }
    },
    "/fridges": {
      "post": {
        "tags": [
          "Fridges"
        ],
        "summary": "Create a new shared fridge",
        "description": "Start a new fridge. You will automatically become the first member, and an invite code will be generated.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Our Apartment Fridge"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Fridge created"
          }
        }
      }
    },
    "/fridges/join": {
      "post": {
        "tags": [
          "Fridges"
        ],
        "summary": "Join a fridge via invite code",
        "description": "Enter a 6-character code to join an existing shared fridge.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "inviteCode"
              ],
              "properties": {
                "inviteCode": {
                  "type": "string",
                  "example": "A1B2C3"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully joined the fridge"
          }
        }
      }
    },
    "/fridges/leave": {
      "post": {
        "tags": [
          "Fridges"
        ],
        "summary": "Leave the current fridge",
        "description": "Removes you from your currently active fridge. If you were the last member, the fridge is destroyed.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Left fridge successfully"
          }
        }
      }
    },
    "/fridges/me": {
      "get": {
        "tags": [
          "Fridges"
        ],
        "summary": "Get my active fridge",
        "description": "Fetches details of the fridge you are currently a part of, including its invite code.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Active fridge details"
          }
        }
      }
    },
    "/fridges/me/members": {
      "get": {
        "tags": [
          "Fridges"
        ],
        "summary": "Get fridge members",
        "description": "Fetches a list of all users who are currently members of your active fridge.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of members"
          }
        }
      }
    },
    "/chats": {
      "get": {
        "tags": [
          "Chat"
        ],
        "summary": "List my chats",
        "description": "Returns all your active messaging threads, sorted by recent activity.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of chats"
          }
        }
      }
    },
    "/chats/{chatId}/messages": {
      "get": {
        "tags": [
          "Chat"
        ],
        "summary": "Get messages for a specific chat",
        "description": "Retrieves message history for a conversation.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "chatId",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages"
          }
        }
      }
    },
    "/chats/private/{userId}": {
      "post": {
        "tags": [
          "Chat"
        ],
        "summary": "Start or find a private chat",
        "description": "Creates a new 1-on-1 chat with another user, or returns the existing chat if one already exists.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "userId",
            "type": "string",
            "required": true,
            "description": "ID of the target user"
          }
        ],
        "responses": {
          "200": {
            "description": "Chat session details"
          }
        }
      }
    },
    "/posts": {
      "post": {
        "tags": [
          "Social Feed (Posts)"
        ],
        "summary": "Create a new post",
        "description": "Publish a post to the social feed. You can include media URLs and an optional location tag.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "text"
              ],
              "properties": {
                "text": {
                  "type": "string",
                  "example": "Look at this amazing cake I made!"
                },
                "mediaUrls": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "https://example.com/cake.jpg"
                  ]
                },
                "location": {
                  "type": "object",
                  "properties": {
                    "lat": {
                      "type": "number",
                      "example": 34.0522
                    },
                    "lng": {
                      "type": "number",
                      "example": -118.2437
                    },
                    "placeName": {
                      "type": "string",
                      "example": "Los Angeles, CA"
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Post successfully created"
          }
        }
      },
      "get": {
        "tags": [
          "Social Feed (Posts)"
        ],
        "summary": "List posts in the feed",
        "description": "Browse posts from all users. Can optionally be filtered by geographical proximity.",
        "parameters": [
          {
            "in": "query",
            "name": "lat",
            "type": "number",
            "description": "Latitude for location-based search"
          },
          {
            "in": "query",
            "name": "lng",
            "type": "number",
            "description": "Longitude for location-based search"
          },
          {
            "in": "query",
            "name": "radiusKm",
            "type": "number",
            "description": "Radius in kilometers for search (default 50)"
          },
          {
            "in": "query",
            "name": "page",
            "type": "integer",
            "default": 1
          },
          {
            "in": "query",
            "name": "limit",
            "type": "integer",
            "default": 20
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of posts"
          }
        }
      }
    },
    "/posts/{post_id}": {
      "put": {
        "tags": [
          "Social Feed (Posts)"
        ],
        "summary": "Edit your post",
        "description": "Modify the text, media, or location of one of your existing posts.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "mediaUrls": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "location": {
                  "type": "object",
                  "properties": {
                    "lat": {
                      "type": "number"
                    },
                    "lng": {
                      "type": "number"
                    },
                    "placeName": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post updated successfully"
          },
          "403": {
            "description": "Not the author of this post"
          }
        }
      },
      "delete": {
        "tags": [
          "Social Feed (Posts)"
        ],
        "summary": "Delete your post",
        "description": "Permanently delete a post from the feed.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Post deleted"
          },
          "403": {
            "description": "Not the author of this post"
          }
        }
      }
    },
    "/posts/{postId}/comments": {
      "get": {
        "tags": [
          "Comments"
        ],
        "summary": "Get comments for a post",
        "description": "Fetches all comments on a specific post.",
        "parameters": [
          {
            "in": "path",
            "name": "postId",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Array of comments"
          }
        }
      },
      "post": {
        "tags": [
          "Comments"
        ],
        "summary": "Add a comment to a post",
        "description": "Publish a new comment under a specific post.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "postId",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "text"
              ],
              "properties": {
                "text": {
                  "type": "string",
                  "example": "Looks delicious!"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Comment added"
          }
        }
      }
    },
    "/posts/{postId}/comments/{commentId}": {
      "delete": {
        "tags": [
          "Comments"
        ],
        "summary": "Delete your comment",
        "description": "Remove your comment from a post.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "postId",
            "type": "string",
            "required": true
          },
          {
            "in": "path",
            "name": "commentId",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Comment deleted"
          },
          "403": {
            "description": "Not the author of this comment"
          }
        }
      }
    },
    "/ai/recipes/generate": {
      "post": {
        "tags": [
          "AI Assistant"
        ],
        "summary": "Generate recipes from ingredients",
        "description": "Provide the AI with a list of ingredients, and get back tailored, creative recipe ideas. Each recipe includes an auto-generated food photo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "ingredients"
              ],
              "properties": {
                "ingredients": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "chicken",
                    "rice",
                    "broccoli"
                  ]
                },
                "allergies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "peanuts"
                  ]
                },
                "dietPreference": {
                  "type": "string",
                  "example": "NONE"
                },
                "count": {
                  "type": "integer",
                  "example": 3
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of AI-generated recipes"
          }
        }
      }
    },
    "/ai/ask": {
      "post": {
        "tags": [
          "AI Assistant"
        ],
        "summary": "Ask cooking questions",
        "description": "A free-form conversational prompt to ask the Culinary AI assistant any culinary questions.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "query"
              ],
              "properties": {
                "query": {
                  "type": "string",
                  "example": "How long should I boil eggs for a soft yolk?"
                },
                "ingredients": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "eggs",
                    "water"
                  ]
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "AI's helpful answer"
          }
        }
      }
    },
    "/upload": {
      "post": {
        "tags": [
          "File Upload"
        ],
        "summary": "Upload an image",
        "description": "Upload an image file (JPEG, PNG, GIF, WebP). Max 5MB. The image is saved to the server and a URL is returned. Used for post images, profile photos, etc.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "formData",
            "name": "image",
            "type": "file",
            "required": true,
            "description": "Image file to upload"
          }
        ],
        "responses": {
          "201": {
            "description": "Image uploaded successfully. Returns { ok: true, data: { imageUrl: '/uploads/filename.jpg' } }"
          },
          "400": {
            "description": "No image uploaded or invalid file type"
          }
        }
      }
    },
    "/recipes/save": {
      "post": {
        "tags": [
          "Saved Recipes"
        ],
        "summary": "Save a recipe to favorites",
        "description": "Save an AI-generated recipe to your personal recipe box.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "title"
              ],
              "properties": {
                "title": {
                  "type": "string",
                  "example": "Chicken Fried Rice"
                },
                "description": {
                  "type": "string",
                  "example": "Quick and easy chicken fried rice"
                },
                "cookingTime": {
                  "type": "string",
                  "example": "20m"
                },
                "difficulty": {
                  "type": "string",
                  "example": "Easy"
                },
                "steps": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "ingredients": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "amount": {
                        "type": "string"
                      }
                    }
                  }
                },
                "imageUrl": {
                  "type": "string",
                  "example": "/uploads/recipe_abc123.png",
                  "description": "URL of the recipe image. Auto-generated by AI or uploaded manually."
                },
                "nutrition": {
                  "type": "object",
                  "properties": {
                    "calories": {
                      "type": "string",
                      "example": "350 kcal"
                    },
                    "protein": {
                      "type": "string",
                      "example": "25g"
                    },
                    "carbs": {
                      "type": "string",
                      "example": "30g"
                    },
                    "fat": {
                      "type": "string",
                      "example": "15g"
                    }
                  }
